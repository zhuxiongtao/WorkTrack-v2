# 对话模型
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL_NAME=deepseek-chat

# Embedding 模型（若不单独配置则自动复用对话模型配置）
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=text-embedding-3-small

# Chroma 持久化目录（已废弃，数据目录由 DATA_ROOT 统一管理）
# CHROMA_PERSIST_DIR=./data/chroma

# 数据库连接（统一使用 PostgreSQL，与生产环境一致）
DATABASE_URL=postgresql://worktrack:worktrack@localhost:5432/worktrack

# JWT 密钥（生产环境务必修改为随机字符串）
JWT_SECRET_KEY=change-me-in-production

# 安全配置
ALLOW_REGISTRATION=false
CORS_ORIGINS=http://localhost:5173
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30
PASSWORD_MIN_LENGTH=8

# ===== 模型目录自动采集（Tavily + LLM 抽取） =====
# Tavily 搜索 API Key（注册：https://tavily.com/）
# 可同时在「设置 → 系统偏好」中以 tavily_api_key 键覆盖
TAVILY_API_KEY=

# 启用模型目录自动刷新（true/false，默认 true）
MODEL_REFRESH_ENABLED=true

# 自动刷新 cron 表达式（标准 5 段：分 时 日 月 周；默认每周一 03:00）
# 0 3 * * 1   = 每周一 03:00
# 0 8 * * *   = 每天 08:00
# 0 3 * * 0   = 每周日 03:00
MODEL_REFRESH_CRON=0 3 * * 1
